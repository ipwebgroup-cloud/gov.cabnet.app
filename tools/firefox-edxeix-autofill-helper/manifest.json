{
  "manifest_version": 2,
  "name": "Gov Cabnet EDXEIX Autofill Helper",
  "version": "6.6.7",
  "description": "Local browser helper for transferring reviewed Bolt pre-ride email fields into the logged-in EDXEIX rental contract form. v6.6.7 adds exact-ID fill and controlled in-page POST/save support.",
  "permissions": [
    "storage",
    "https://gov.cabnet.app/*",
    "https://edxeix.yme.gov.gr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gov.cabnet.app/ops/pre-ride-email-tool.php*"
      ],
      "js": [
        "gov-capture.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://edxeix.yme.gov.gr/*"
      ],
      "js": [
        "edxeix-fill.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "gov-cabnet-edxeix-autofill-helper@cabnet.app",
      "strict_min_version": "109.0"
    }
  }
}
